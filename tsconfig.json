{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "outDir": "web/js",
    "rootDir": "web/src",
    "skipLibCheck": true,
    "declaration": false,
    "sourceMap": false,
    "newLine": "crlf"
  },
  "include": ["web/src/**/*.ts"]
}